# Firebase 웹 앱 설정 — Firebase 콘솔 > 프로젝트 설정 > "웹 앱 추가"에서 발급.
# 실제 값을 채워 web/.env.local 로 복사하세요. (앱과 같은 프로젝트: policy-alerm)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=policy-alerm.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=policy-alerm
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=policy-alerm.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=249888568978
NEXT_PUBLIC_FIREBASE_APP_ID=

# 배포 도메인 (sitemap/canonical 에 사용). 커스텀 도메인이 있으면 교체.
NEXT_PUBLIC_SITE_URL=https://policy-alerm.web.app

# 정책 데이터 CDN (보통 변경 불필요).
NEXT_PUBLIC_CDN_BASE=https://jykim1011.github.io/policy-alerm
